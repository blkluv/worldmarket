# WorldMarket Environment Variables
# Copy to .env and fill in values before running

# ─── Contracts ────────────────────────────────────────────────
# Your private key for deploying contracts (Foundry)
PRIVATE_KEY=0x...

# Base Sepolia RPC URL
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ─── API Server ───────────────────────────────────────────────
# Deployed HumanRegistry proxy address
HUMAN_REGISTRY_ADDRESS=0x...

# Deployed WorldMarket proxy address
WORLD_MARKET_ADDRESS=0x...

# Admin/signer private key — signs bet() transactions on-chain
ADMIN_PRIVATE_KEY=0x...

# Address that receives x402 micropayment fees
PAYMENT_RECIPIENT=0x...

# API server port (default: 3001)
PORT=3001

# ─── Agent Bot ────────────────────────────────────────────────
# Agent wallet private key (must be registered via HumanRegistry.registerAgent())
AGENT_PRIVATE_KEY=0x...

# URL of the running API server
API_URL=http://localhost:3001

# ─── Frontend (public, exposed to browser) ────────────────────
# HumanRegistry proxy address (same as HUMAN_REGISTRY_ADDRESS)
NEXT_PUBLIC_REGISTRY_ADDRESS=0x...

# WorldMarket proxy address (same as WORLD_MARKET_ADDRESS)
NEXT_PUBLIC_MARKET_ADDRESS=0x...

# World ID application ID (from developer.worldcoin.org)
NEXT_PUBLIC_WLD_APP_ID=app_...

# API server URL accessible from the browser
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── XMTP (Agent Chat — Track F) ──────────────────────────────
# XMTP environment: "dev" for testnet (default), "production" for mainnet
XMTP_ENV=dev

# XMTP group ID for agent-chat broadcast channel
# Create via: node agent/scripts/createXmtpGroup.js  (see bootstrap procedure)
XMTP_GROUP_ID=

# Owner address for XMTP command authorization
OWNER_ADDRESS=
# Agent XMTP address for the frontend to send commands to
NEXT_PUBLIC_AGENT_XMTP_ADDRESS=

# Demo mode for frontend (bypasses real World ID scan)
NEXT_PUBLIC_DEMO_MODE=true

# Frontend: same group ID, exposed to the browser
NEXT_PUBLIC_XMTP_GROUP_ID=

# Frontend: XMTP environment for the browser SDK
NEXT_PUBLIC_XMTP_ENV=dev

# RP signing key from World Developer Portal (never expose to client)
RP_SIGNING_KEY=...

# RP ID from World Developer Portal (e.g., "rp_123456789abcdef0")
RP_ID=rp_...
